{
  "name": "homebridge-vera2",
  "displayName": "Homebridge Vera 2",
  "version": "0.1.0",
  "description": "Homebridge 2.0 dynamic platform plugin for Vera (MiCasaVerde / Ezlo) controllers over the local Luup HTTP API.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.14.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "keywords": [
    "homebridge-plugin",
    "vera",
    "micasaverde",
    "ezlo",
    "luup",
    "smarthome",
    "homekit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mckdevnull/homebridge-vera2.git"
  },
  "bugs": {
    "url": "https://github.com/mckdevnull/homebridge-vera2/issues"
  },
  "files": [
    "dist",
    "config.schema.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/clean.mjs && tsc",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "homebridge": "^2.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
